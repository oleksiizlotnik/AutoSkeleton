{
  "name": "auto-skeleton-vue",
  "version": "0.1.1",
  "description": "Auto-generated Vue 3 skeleton loaders that mirror a component's real rendered layout — zero authoring, always in sync.",
  "type": "module",
  "license": "MIT",
  "author": "Oleksii Zlotnik <alexeyzlotnik@gmail.com> (https://github.com/oleksiizlotnik)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oleksiizlotnik/AutoSkeleton.git"
  },
  "homepage": "https://oleksiizlotnik.github.io/AutoSkeleton/",
  "bugs": {
    "url": "https://github.com/oleksiizlotnik/AutoSkeleton/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "vue-3",
    "vuejs",
    "skeleton",
    "skeleton-loader",
    "skeleton-screen",
    "skeleton-loading",
    "loading",
    "loading-placeholder",
    "placeholder",
    "content-placeholder",
    "shimmer",
    "spinner",
    "loader",
    "ghost-loading",
    "composable",
    "typescript"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/auto-skeleton.cjs",
  "module": "./dist/auto-skeleton.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auto-skeleton.js",
      "require": "./dist/auto-skeleton.cjs"
    },
    "./style.css": "./dist/auto-skeleton.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build && npm test",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write ."
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.20.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitepress": "^1.6.0",
    "vitest": "^1.5.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
